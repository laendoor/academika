{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "dev-api",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "app.main:app",
        "--host", "0.0.0.0",
        "--port", "8000",
        "--log-config", "log_config.dev.yaml"
      ],
      "cwd": "${workspaceFolder}/api",
      "python": "${workspaceFolder}/api/.venv/bin/python",
      "jinja": true,
      "justMyCode": true,
      "env": {
        "DATABASE_URL": "postgresql+asyncpg://academika:academika@localhost:5432/academika"
      }
    }
  ]
}
