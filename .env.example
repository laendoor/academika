# ── API ─────────────────────────────────────────────────────────────────────
# Variables leídas por api/app/config.py (pydantic-settings).
# Cada campo de Settings se mapea a su env var en UPPER_SNAKE_CASE.
# Los defaults del código solo aplican en dev/test local — en prod deben setearse.

DATABASE_URL=postgresql+asyncpg://academika:academika@postgres:5432/academika

# Requerido en prod. Generar con: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=dev-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
RESET_TOKEN_EXPIRE_HOURS=1

# Requerido en prod. Obtener en resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@academika.unq.edu.ar
FRONTEND_URL=http://localhost:3000

# ── UI ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
