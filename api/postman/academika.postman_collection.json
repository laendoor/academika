{
  "info": {
    "name": "Académika API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Endpoints base de Académika — Fase 2 (tickets #3, #6)"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000", "type": "string" },
    { "key": "access_token", "value": "", "type": "string" },
    { "key": "refresh_token", "value": "", "type": "string" },
    { "key": "degree_id", "value": "", "type": "string" },
    { "key": "course_id", "value": "", "type": "string" },
    { "key": "plan_id", "value": "", "type": "string" },
    { "key": "student_id", "value": "", "type": "string" },
    { "key": "enrollment_id", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /auth/login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('access_token', json.access_token);",
                  "  pm.collectionVariables.set('refresh_token', json.refresh_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"lean@unq.edu.ar\",\n  \"password\": \"Test1234!\"\n}"
            }
          }
        },
        {
          "name": "POST /auth/refresh",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('access_token', json.access_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/refresh",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            }
          }
        },
        {
          "name": "POST /auth/forgot-password",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/forgot-password",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"lean@unq.edu.ar\"\n}"
            }
          }
        },
        {
          "name": "POST /auth/reset-password",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/reset-password",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"\",\n  \"new_password\": \"NewPassword1!\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Carreras",
      "item": [
        {
          "name": "GET /api/v1/carreras",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/carreras?skip=0&limit=20",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "carreras"],
              "query": [
                { "key": "skip", "value": "0" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "POST /api/v1/carreras",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/carreras",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Tecnicatura en Programación Informática\",\n  \"code\": \"TPI\"\n}"
            }
          }
        },
        {
          "name": "GET /api/v1/carreras/:id",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/carreras/{{degree_id}}"
          }
        },
        {
          "name": "PUT /api/v1/carreras/:id",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/v1/carreras/{{degree_id}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Tecnicatura en Programación Informática (actualizada)\"\n}"
            }
          }
        },
        {
          "name": "DELETE /api/v1/carreras/:id",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/v1/carreras/{{degree_id}}"
          }
        }
      ]
    },
