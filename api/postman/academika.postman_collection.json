            "body": {
              "mode": "raw",
              "raw": "{\n  \"is_active\": false,\n  \"course_ids\": [\"{{course_id}}\"]\n}"
            }
          }
        },
        {
          "name": "DELETE /api/v1/planes/:id",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/v1/planes/{{plan_id}}"
          }
        }
