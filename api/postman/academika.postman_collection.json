    {
      "name": "Inscripciones",
      "item": [
        {
          "name": "GET /api/v1/inscripciones",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/inscripciones?skip=0&limit=20",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "inscripciones"],
              "query": [
                { "key": "skip", "value": "0" },
                { "key": "limit", "value": "20" },
                { "key": "student_id", "value": "", "disabled": true },
                { "key": "course_id", "value": "", "disabled": true },
                { "key": "year", "value": "", "disabled": true },
                { "key": "term", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "POST /api/v1/inscripciones",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/inscripciones",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"student_id\": \"{{student_id}}\",\n  \"course_id\": \"{{course_id}}\",\n  \"year\": 2024,\n  \"term\": \"1C\",\n  \"section\": null,\n  \"enrollment_type\": \"regular\",\n  \"enrollment_status\": \"inscripto\",\n  \"grade\": null,\n  \"enrolled_at\": null\n}"
            }
          }
        },
        {
          "name": "GET /api/v1/inscripciones/:id",
